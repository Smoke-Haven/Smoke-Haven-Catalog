{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm run build",
  "builds": [
    {
      "src": "dist/index.mjs",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dist/index.mjs"
    },
    {
      "src": "/healthz",
      "dest": "dist/index.mjs"
    }
  ]
}
