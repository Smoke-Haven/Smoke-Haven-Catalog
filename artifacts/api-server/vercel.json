{
  "version": 2,
  "buildCommand": "cd ../.. && pnpm install && pnpm run -w --filter=@workspace/api-server build",
  "builds": [
    {
      "src": "artifacts/api-server/dist/index.mjs",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["artifacts/api-server/dist/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    },
    {
      "src": "/healthz",
      "dest": "artifacts/api-server/dist/index.mjs"
    }
  ]
}
